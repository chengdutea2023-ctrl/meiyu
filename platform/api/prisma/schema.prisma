generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum UserType {
  STUDENT
  TEACHER
  ADMIN
}

enum UserApprovalStatus {
  APPROVED
  PENDING
  REJECTED
}

enum OrganizationType {
  SCHOOL
  INSTITUTION
  INTERNAL
}

enum OrganizationStatus {
  ACTIVE
  DISABLED
}

enum ClassStatus {
  ACTIVE
  ARCHIVED
}

enum RoleScope {
  PLATFORM
  ORGANIZATION
  APPLICATION
}

enum ApplicationStatus {
  ACTIVE
  DISABLED
}

enum AuthorizationCodeStatus {
  ACTIVE
  USED
  EXPIRED
  REVOKED
}

enum ClassMemberRole {
  TEACHER
  STUDENT
  ASSISTANT
}

enum CourseRuntimeType {
  STATIC
  NODE
  BOTH
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CourseOwnerType {
  ADMIN
  TEACHER
  DEVELOPER
}

enum CourseAssignmentStatus {
  ACTIVE
  ARCHIVED
}

enum CourseTeachingStatus {
  READY
  OPEN
  ENDED
}

enum LearningRecordStatus {
  STARTED
  PROGRESS
  COMPLETED
}

enum WorkItemAudience {
  ADMIN
  TEACHER
}

enum WorkItemStatus {
  PENDING
  DONE
}

enum WorkItemType {
  STUDENT_REGISTERED
  TEACHER_PENDING_APPROVAL
  LEARNING_RECORD_COMPLETED
  COURSEWARE_DEPLOYMENT_FAILED
}

model User {
  id                  String              @id @default(cuid())
  username            String?             @unique
  email               String              @unique
  passwordHash        String?
  displayName         String?
  userType            UserType            @default(STUDENT)
  approvalStatus      UserApprovalStatus  @default(APPROVED)
  ageBand             String?
  status              UserStatus          @default(ACTIVE)
  isPlatformAdmin     Boolean             @default(false)
  sourceApplicationId String?
  sourceApplication   Application?        @relation("SourceApplicationUsers", fields: [sourceApplicationId], references: [id], onDelete: SetNull)
  applicationUsers    ApplicationUser[]
  organizations       UserOrganization[]
  classes             UserClass[]
  createdCourses      Course[]            @relation("CourseCreator")
  courseAssignments   CourseAssignment[]  @relation("CourseAssignmentTeacher")
  learningRecords     LearningRecord[]    @relation("LearningRecordStudent")
  courseLaunchSessions CourseLaunchSession[] @relation("CourseLaunchSessionStudent")
  recipientWorkItems  WorkItem[]          @relation("WorkItemRecipient")
  sourceWorkItems     WorkItem[]          @relation("WorkItemSourceUser")
  completedWorkItems  WorkItem[]          @relation("WorkItemCompletedBy")
  authCodes           AuthorizationCode[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  deletedAt           DateTime?

  @@index([sourceApplicationId])
  @@index([userType])
  @@index([approvalStatus])
  @@index([deletedAt])
}

model Organization {
  id                  String                          @id @default(cuid())
  name                String
  code                String?                         @unique
  type                OrganizationType                @default(SCHOOL)
  status              OrganizationStatus              @default(ACTIVE)
  classes             Class[]
  members             UserOrganization[]
  applicationAccesses ApplicationOrganizationAccess[]
  createdAt           DateTime                        @default(now())
  updatedAt           DateTime                        @updatedAt
}

model Class {
  id                  String                   @id @default(cuid())
  name                String
  code                String?
  status              ClassStatus              @default(ACTIVE)
  organizationId      String
  organization        Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members             UserClass[]
  applicationAccesses ApplicationClassAccess[]
  courseAssignments   CourseAssignment[]
  learningRecords     LearningRecord[]
  courseLaunchSessions CourseLaunchSession[]
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@unique([organizationId, code])
  @@index([organizationId])
}

model Course {
  id              String             @id @default(cuid())
  slug            String             @unique
  title           String
  description     String?
  runtimeType     CourseRuntimeType  @default(STATIC)
  entryUrl        String
  status          CourseStatus       @default(DRAFT)
  ownerType       CourseOwnerType    @default(ADMIN)
  manifest        Json?
  manifestValid   Boolean            @default(false)
  manifestErrors  String[]           @default([])
  deploymentStatus  String           @default("NOT_UPLOADED")
  deploymentMessage String?
  nodePort        Int?
  uploadedAt      DateTime?
  deployedAt      DateTime?
  createdByUserId String?
  createdByUser   User?              @relation("CourseCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  coursewares     Courseware[]
  assignments     CourseAssignment[]
  learningRecords LearningRecord[]
  launchSessions  CourseLaunchSession[]
  coursewareLinks  CourseCourseware[]
  workItems       WorkItem[]         @relation("WorkItemCourse")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?

  @@index([status])
  @@index([ownerType])
  @@index([createdByUserId])
  @@index([deletedAt])
}

model Courseware {
  id                String             @id @default(cuid())
  courseId          String
  slug              String
  title             String
  description       String?
  sortOrder         Int                @default(0)
  runtimeType       CourseRuntimeType  @default(STATIC)
  entryUrl          String
  status            CourseStatus       @default(DRAFT)
  manifest          Json?
  manifestValid     Boolean            @default(false)
  manifestErrors    String[]           @default([])
  deploymentStatus  String             @default("NOT_UPLOADED")
  deploymentMessage String?
  nodePort          Int?
  uploadedAt        DateTime?
  deployedAt        DateTime?
  course            Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  learningRecords   LearningRecord[]
  launchSessions    CourseLaunchSession[]
  courseLinks        CourseCourseware[]
  workItems         WorkItem[]         @relation("WorkItemCourseware")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?

  @@unique([courseId, slug])
  @@index([courseId])
  @@index([status])
  @@index([sortOrder])
  @@index([deletedAt])
  @@index([courseId, deletedAt])
}

model CourseCourseware {
  id           String     @id @default(cuid())
  courseId     String
  coursewareId String
  sortOrder    Int        @default(0)
  course       Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseware   Courseware @relation(fields: [coursewareId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([courseId, coursewareId])
  @@index([courseId, sortOrder])
  @@index([coursewareId])
}

model CourseAssignment {
  id              String                 @id @default(cuid())
  courseId        String
  classId         String
  teacherId       String
  title           String
  instructions    String?
  startAt         DateTime?
  dueAt           DateTime?
  status          CourseAssignmentStatus @default(ACTIVE)
  teachingStatus  CourseTeachingStatus   @default(READY)
  openedAt        DateTime?
  closedAt        DateTime?
  openedByUserId  String?
  closedByUserId  String?
  course          Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  class           Class                  @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher         User                   @relation("CourseAssignmentTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  learningRecords LearningRecord[]
  launchSessions  CourseLaunchSession[]
  workItems       WorkItem[]             @relation("WorkItemAssignment")
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([courseId])
  @@index([classId])
  @@index([teacherId])
  @@index([status])
  @@index([teachingStatus])
}

model LearningRecord {
  id              String               @id @default(cuid())
  courseId        String
  coursewareId    String
  assignmentId    String?
  classId         String?
  studentId       String
  status          LearningRecordStatus @default(STARTED)
  score           Float?
  durationSeconds Int?
  summary         Json?
  startedAt       DateTime?
  completedAt     DateTime?
  course          Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseware      Courseware           @relation(fields: [coursewareId], references: [id], onDelete: Cascade)
  assignment      CourseAssignment?    @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  class           Class?               @relation(fields: [classId], references: [id], onDelete: SetNull)
  student         User                 @relation("LearningRecordStudent", fields: [studentId], references: [id], onDelete: Cascade)
  workItems       WorkItem[]           @relation("WorkItemLearningRecord")
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([courseId])
  @@index([coursewareId])
  @@index([assignmentId])
  @@index([classId])
  @@index([studentId])
  @@index([status])
}

model WorkItem {
  id                String           @id @default(cuid())
  uniqueKey         String           @unique
  type              WorkItemType
  audience          WorkItemAudience
  status            WorkItemStatus   @default(PENDING)
  recipientUserId   String?
  recipientUser     User?            @relation("WorkItemRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  title             String
  description       String?
  actionLabel       String?
  sourceUserId      String?
  sourceUser        User?            @relation("WorkItemSourceUser", fields: [sourceUserId], references: [id], onDelete: SetNull)
  courseId          String?
  course            Course?          @relation("WorkItemCourse", fields: [courseId], references: [id], onDelete: SetNull)
  coursewareId      String?
  courseware        Courseware?      @relation("WorkItemCourseware", fields: [coursewareId], references: [id], onDelete: SetNull)
  assignmentId      String?
  assignment        CourseAssignment? @relation("WorkItemAssignment", fields: [assignmentId], references: [id], onDelete: SetNull)
  learningRecordId  String?
  learningRecord    LearningRecord?  @relation("WorkItemLearningRecord", fields: [learningRecordId], references: [id], onDelete: SetNull)
  metadata          Json?
  completedAt       DateTime?
  completedByUserId String?
  completedByUser   User?            @relation("WorkItemCompletedBy", fields: [completedByUserId], references: [id], onDelete: SetNull)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([audience, status])
  @@index([recipientUserId, status])
  @@index([type, status])
  @@index([sourceUserId])
  @@index([courseId])
  @@index([coursewareId])
  @@index([assignmentId])
  @@index([learningRecordId])
  @@index([completedByUserId])
  @@index([createdAt])
}

model CourseLaunchSession {
  id             String            @id @default(cuid())
  tokenHash      String            @unique
  courseId       String
  coursewareId   String
  assignmentId   String?
  classId        String?
  studentId      String
  expiresAt      DateTime
  lastVerifiedAt DateTime?
  course         Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseware     Courseware        @relation(fields: [coursewareId], references: [id], onDelete: Cascade)
  assignment     CourseAssignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  class          Class?            @relation(fields: [classId], references: [id], onDelete: SetNull)
  student        User              @relation("CourseLaunchSessionStudent", fields: [studentId], references: [id], onDelete: Cascade)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([courseId])
  @@index([coursewareId])
  @@index([assignmentId])
  @@index([classId])
  @@index([studentId])
  @@index([expiresAt])
}

model Role {
  id              String             @id @default(cuid())
  key             String             @unique
  name            String
  scope           RoleScope
  description     String?
  permissions     String[]           @default([])
  userMemberships UserOrganization[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model UserOrganization {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  roleId         String?
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           Role?        @relation(fields: [roleId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model UserClass {
  id        String          @id @default(cuid())
  userId    String
  classId   String
  role      ClassMemberRole @default(STUDENT)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  class     Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())

  @@unique([userId, classId])
  @@index([classId])
}

model Application {
  id                   String                          @id @default(cuid())
  appId                String                          @unique
  appSecretHash        String
  name                 String
  description          String?
  homeUrl              String
  allowedOrigins       String[]                        @default([])
  redirectUris         String[]
  status               ApplicationStatus               @default(ACTIVE)
  sourceUsers          User[]                          @relation("SourceApplicationUsers")
  applicationUsers     ApplicationUser[]
  organizationAccesses ApplicationOrganizationAccess[]
  classAccesses        ApplicationClassAccess[]
  authCodes            AuthorizationCode[]
  refreshTokens        RefreshToken[]
  createdAt            DateTime                        @default(now())
  updatedAt            DateTime                        @updatedAt
}

model ApplicationOrganizationAccess {
  id             String       @id @default(cuid())
  applicationId  String
  organizationId String
  application    Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([applicationId, organizationId])
  @@index([organizationId])
}

model ApplicationClassAccess {
  id            String      @id @default(cuid())
  applicationId String
  classId       String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  class         Class       @relation(fields: [classId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([applicationId, classId])
  @@index([classId])
}

model ApplicationUser {
  id             String      @id @default(cuid())
  applicationId  String
  userId         String
  externalUserId String
  email          String
  username       String?
  displayName    String?
  ageBand        String?
  agentName      String?
  emailVerified  Boolean     @default(false)
  application    Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstLinkedAt  DateTime    @default(now())
  lastSyncedAt   DateTime    @updatedAt

  @@unique([applicationId, externalUserId])
  @@unique([applicationId, email])
  @@index([userId])
  @@index([email])
  @@index([applicationId, agentName])
}

model AuthorizationCode {
  id            String                  @id @default(cuid())
  codeHash      String                  @unique
  userId        String
  applicationId String
  redirectUri   String
  scope         String?
  status        AuthorizationCodeStatus @default(ACTIVE)
  expiresAt     DateTime
  usedAt        DateTime?
  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  application   Application             @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  createdAt     DateTime                @default(now())

  @@index([userId])
  @@index([applicationId])
  @@index([expiresAt])
}

model RefreshToken {
  id            String       @id @default(cuid())
  tokenHash     String       @unique
  userId        String
  applicationId String?
  expiresAt     DateTime
  revokedAt     DateTime?
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())

  @@index([userId])
  @@index([applicationId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}
