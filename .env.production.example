# Copy this file to .env.production on the ECS server and replace all placeholder values.

# Public address
ECS_PUBLIC_IP="YOUR_ECS_PUBLIC_IP"
PLATFORM_PUBLIC_URL="http://YOUR_ECS_PUBLIC_IP:3000"
VITE_API_BASE_URL="http://YOUR_ECS_PUBLIC_IP:3000/api/v1"
CORS_ORIGINS="http://YOUR_ECS_PUBLIC_IP:8080,http://YOUR_ECS_PUBLIC_IP:3001"

# Ports exposed by Docker Compose
API_PUBLIC_PORT=3000
ADMIN_WEB_PUBLIC_PORT=8080
DEMO_APP_PUBLIC_PORT=3001
POSTGRES_PUBLIC_PORT=5432
POSTGRES_BIND_ADDR="127.0.0.1"
REDIS_PUBLIC_PORT=6379
REDIS_BIND_ADDR="127.0.0.1"

# Database
POSTGRES_USER="jiaoxue"
POSTGRES_PASSWORD="CHANGE_ME_STRONG_POSTGRES_PASSWORD"
POSTGRES_DB="jiaoxue_platform"
DATABASE_URL="postgresql://jiaoxue:CHANGE_ME_STRONG_POSTGRES_PASSWORD@postgres:5432/jiaoxue_platform?schema=public"

# Redis
REDIS_URL="redis://redis:6379/0"

# API runtime
PORT=3000
JWT_ACCESS_SECRET="CHANGE_ME_LONG_RANDOM_ACCESS_SECRET"
JWT_REFRESH_SECRET="CHANGE_ME_LONG_RANDOM_REFRESH_SECRET"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
AUTH_CODE_TTL_SECONDS=120

# Initial seed data
ADMIN_USERNAME="admin"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="CHANGE_ME_ADMIN_PASSWORD"
DEMO_APP_ID="demo-teaching-app"
DEMO_APP_SECRET="CHANGE_ME_DEMO_APP_SECRET"
DEMO_APP_PORT=3001
DEMO_APP_PUBLIC_URL="http://YOUR_ECS_PUBLIC_IP:3001"
